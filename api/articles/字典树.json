 8.97 6.07 10.84 6.01 13.27C6 13.33 6 13.4 6 13.47V13.5\"></path>\n<path stroke-linejoin=\"round\" stroke-linecap=\"round\" stroke-miterlimit=\"10\" stroke-width=\"2\" stroke=\"\" d=\"M15.97 11.5H16.04C17.12 11.5 18 12.38 18 13.47V13.53C18 14.62 17.12 15.5 16.03 15.5H15.96C14.88 15.5 14 14.62 14 13.53V13.46C14 12.38 14.88 11.5 15.97 11.5Z\"></path>\n<path stroke-linejoin=\"round\" stroke-linecap=\"round\" stroke-miterlimit=\"10\" stroke-width=\"2\" stroke=\"\" d=\"M7.97 11.5H8.04C9.12 11.5 10 12.38 10 13.47V13.53C10 14.62 9.12 15.5 8.03 15.5H7.97C6.88 15.5 6 14.62 6 13.53V13.46C6 12.38 6.88 11.5 7.97 11.5Z\"></path>\n</svg>\n</span><p>4.一棵单词查找树中的链接总数在<mjx-container class=\"MathJax\" jax=\"SVG\"><svg style=\"vertical-align: -0.048ex\" xmlns=\"http://www.w3.org/2000/svg\" width=\"3.726ex\" height=\"1.593ex\" role=\"img\" focusable=\"false\" viewBox=\"0 -683 1647 704\"><g stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" transform=\"scale(1,-1)\"><g data-mml-node=\"math\"><g data-mml-node=\"mi\"><path data-c=\"1D445\" d=\"M230 637Q203 637 198 638T193 649Q193 676 204 682Q206 683 378 683Q550 682 564 680Q620 672 658 652T712 606T733 563T739 529Q739 484 710 445T643 385T576 351T538 338L545 333Q612 295 612 223Q612 212 607 162T602 80V71Q602 53 603 43T614 25T640 16Q668 16 686 38T712 85Q717 99 720 102T735 105Q755 105 755 93Q755 75 731 36Q693 -21 641 -21H632Q571 -21 531 4T487 82Q487 109 502 166T517 239Q517 290 474 313Q459 320 449 321T378 323H309L277 193Q244 61 244 59Q244 55 245 54T252 50T269 48T302 46H333Q339 38 339 37T336 19Q332 6 326 0H311Q275 2 180 2Q146 2 117 2T71 2T50 1Q33 1 33 10Q33 12 36 24Q41 43 46 45Q50 46 61 46H67Q94 46 127 49Q141 52 146 61Q149 65 218 339T287 628Q287 635 230 637ZM630 554Q630 586 609 608T523 636Q521 636 500 636T462 637H440Q393 637 386 627Q385 624 352 494T319 361Q319 360 388 360Q466 361 492 367Q556 377 592 426Q608 449 619 486T630 554Z\"></path></g><g data-mml-node=\"mi\" transform=\"translate(759,0)\"><path data-c=\"1D441\" d=\"M234 637Q231 637 226 637Q201 637 196 638T191 649Q191 676 202 682Q204 683 299 683Q376 683 387 683T401 677Q612 181 616 168L670 381Q723 592 723 606Q723 633 659 637Q635 637 635 648Q635 650 637 660Q641 676 643 679T653 683Q656 683 684 682T767 680Q817 680 843 681T873 682Q888 682 888 672Q888 650 880 642Q878 637 858 637Q787 633 769 597L620 7Q618 0 599 0Q585 0 582 2Q579 5 453 305L326 604L261 344Q196 88 196 79Q201 46 268 46H278Q284 41 284 38T282 19Q278 6 272 0H259Q228 2 151 2Q123 2 100 2T63 2T46 1Q31 1 31 10Q31 14 34 26T39 40Q41 46 62 46Q130 49 150 85Q154 91 221 362L289 634Q287 635 234 637Z\"></path></g></g></g></svg></mjx-container>到<mjx-container class=\"MathJax\" jax=\"SVG\"><svg style=\"vertical-align: -0.048ex\" xmlns=\"http://www.w3.org/2000/svg\" width=\"5.346ex\" height=\"1.593ex\" role=\"img\" focusable=\"false\" viewBox=\"0 -683 2363 704\"><g stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" transform=\"scale(1,-1)\"><g data-mml-node=\"math\"><g data-mml-node=\"mi\"><path data-c=\"1D445\" d=\"M230 637Q203 637 198 638T193 649Q193 676 204 682Q206 683 378 683Q550 682 564 680Q620 672 658 652T712 606T733 563T739 529Q739 484 710 445T643 385T576 351T538 338L545 333Q612 295 612 223Q612 212 607 162T602 80V71Q602 53 603 43T614 25T640 16Q668 16 686 38T712 85Q717 99 720 102T735 105Q755 105 755 93Q755 75 731 36Q693 -21 641 -21H632Q571 -21 531 4T487 82Q487 109 502 166T517 239Q517 290 474 313Q459 320 449 321T378 323H309L277 193Q244 61 244 59Q244 55 245 54T252 50T269 48T302 46H333Q339 38 339 37T336 19Q332 6 326 0H311Q275 2 180 2Q146 2 117 2T71 2T50 1Q33 1 33 10Q33 12 36 24Q41 43 46 45Q50 46 61 46H67Q94 46 127 49Q141 52 146 61Q149 65 218 339T287 628Q287 635 230 637ZM630 554Q630 586 609 608T523 636Q521 636 500 636T462 637H440Q393 637 386 627Q385 624 352 494T319 361Q319 360 388 360Q466 361 492 367Q556 377 592 426Q608 449 619 486T630 554Z\"></path></g><g data-mml-node=\"mi\" transform=\"translate(759,0)\"><path data-c=\"1D441\" d=\"M234 637Q231 637 226 637Q201 637 196 638T191 649Q191 676 202 682Q204 683 299 683Q376 683 387 683T401 677Q612 181 616 168L670 381Q723 592 723 606Q723 633 659 637Q635 637 635 648Q635 650 637 660Q641 676 643 679T653 683Q656 683 684 682T767 680Q817 680 843 681T873 682Q888 682 888 672Q888 650 880 642Q878 637 858 637Q787 633 769 597L620 7Q618 0 599 0Q585 0 582 2Q579 5 453 305L326 604L261 344Q196 88 196 79Q201 46 268 46H278Q284 41 284 38T282 19Q278 6 272 0H259Q228 2 151 2Q123 2 100 2T63 2T46 1Q31 1 31 10Q31 14 34 26T39 40Q41 46 62 46Q130 49 150 85Q154 91 221 362L289 634Q287 635 234 637Z\"></path></g><g data-mml-node=\"mi\" transform=\"translate(1647,0)\"><path data-c=\"1D464\" d=\"M580 385Q580 406 599 424T641 443Q659 443 674 425T690 368Q690 339 671 253Q656 197 644 161T609 80T554 12T482 -11Q438 -11 404 5T355 48Q354 47 352 44Q311 -11 252 -11Q226 -11 202 -5T155 14T118 53T104 116Q104 170 138 262T173 379Q173 380 173 381Q173 390 173 393T169 400T158 404H154Q131 404 112 385T82 344T65 302T57 280Q55 278 41 278H27Q21 284 21 287Q21 293 29 315T52 366T96 418T161 441Q204 441 227 416T250 358Q250 340 217 250T184 111Q184 65 205 46T258 26Q301 26 334 87L339 96V119Q339 122 339 128T340 136T341 143T342 152T345 165T348 182T354 206T362 238T373 281Q402 395 406 404Q419 431 449 431Q468 431 475 421T483 402Q483 389 454 274T422 142Q420 131 420 107V100Q420 85 423 71T442 42T487 26Q558 26 600 148Q609 171 620 213T632 273Q632 306 619 325T593 357T580 385Z\"></path></g></g></g></svg></mjx-container>之间，其中<mjx-container class=\"MathJax\" jax=\"SVG\"><svg style=\"vertical-align: -0.025ex\" xmlns=\"http://www.w3.org/2000/svg\" width=\"1.62ex\" height=\"1.027ex\" role=\"img\" focusable=\"false\" viewBox=\"0 -443 716 454\"><g stroke=\"currentColor\" fill=\"currentColor\" stroke-width=\"0\" transform=\"scale(1,-1)\"><g data-mml-node=\"math\"><g data-mml-node=\"mi\"><path data-c=\"1D464\" d=\"M580 385Q580 406 599 424T641 443Q659 443 674 425T690 368Q690 339 671 253Q656 197 644 161T609 80T554 12T482 -11Q438 -11 404 5T355 48Q354 47 352 44Q311 -11 252 -11Q226 -11 202 -5T155 14T118 53T104 116Q104 170 138 262T173 379Q173 380 173 381Q173 390 173 393T169 400T158 404H154Q131 404 112 385T82 344T65 302T57 280Q55 278 41 278H27Q21 284 21 287Q21 293 29 315T52 366T96 418T161 441Q204 441 227 416T250 358Q250 340 217 250T184 111Q184 65 205 46T258 26Q301 26 334 87L339 96V119Q339 122 339 128T340 136T341 143T342 152T345 165T348 182T354 206T362 238T373 281Q402 395 406 404Q419 431 449 431Q468 431 475 421T483 402Q483 389 454 274T422 142Q420 131 420 107V100Q420 85 423 71T442 42T487 26Q558 26 600 148Q609 171 620 213T632 273Q632 306 619 325T593 357T580 385Z\"></path></g></g></g></svg></mjx-container>为键的平均长度</p></blockquote>\n<p>我们在实际应用中采用单词查找树之前了解将要被插入的所有键的性质是十分重要的；</p>\n<h4 id=\"4-常见应用\"><a href=\"#4-常见应用\" class=\"headerlink\" title=\"4.常见应用\"></a>4.常见应用</h4><p>字典树中其实还可以实现一些常用的公共方法：</p>\n<h5 id=\"公共前缀\"><a href=\"#公共前缀\" class=\"headerlink\" title=\"公共前缀\"></a>公共前缀</h5><p>给定一个前缀，可以求出字典树中所有以该前缀开始的字符串；由于我们是隐式地将字符和键保存在字典树中，所以使能够遍历符号表中的所有键就需要一些额外的思考和操作。首先实现一个方法:</p>\n<pre class=\"line-numbers language-java\" data-language=\"java\"><code class=\"language-java\">private void collect(Node x, StringBuilder prefix, Queue&lt;String&gt; results) {\n    if (x == null) return;\n    if (x.val != null) results.enqueue(prefix.toString());\n    for (char c = 0; c &lt; R; c++) {\n        prefix.append(c);\n        collect(x.next[c], prefix, results);\n        prefix.deleteCharAt(prefix.length() - 1);\n    }\n}</code></pre>\n\n<p>该方法使用一个队列储存字符串，然后使用回溯的方法遍历即可；该方法应从找到前缀的那个结点开始调用，所以：</p>\n<pre class=\"line-numbers language-java\" data-language=\"java\"><code class=\"language-java\">public Iterable&lt;String&gt; keysWithPrefix(String prefix) {\n    Queue&lt;String&gt; results = new Queue&lt;String&gt;();\n    Node x = get(root, prefix, 0);\n    collect(x, new StringBuilder(prefix), results);\n    return results;\n}</code></pre>\n\n<h5 id=\"最长前缀\"><a href=\"#最长前缀\" class=\"headerlink\" title=\"最长前缀\"></a>最长前缀</h5><p>我们有时需要找到给定字符串的最长键前缀，就需要实现类似于<code>get()</code>的递归方法：</p>\n<pre class=\"line-numbers language-java\" data-language=\"java\"><code class=\"language-java\">private int longestPrefixOf(Node x, String query, int d, int length) {\n    if (x == null) return length;\n    if (x.val != null) length = d;\n    if (d == query.length()) return length;\n    char c = query.charAt(d);\n    return longestPrefixOf(x.next[c], query, d + 1, length);\n}</code></pre>\n\n<p>然后公共方法直接从根节点调用它即可：</p>\n<pre class=\"line-numbers language-java\" data-language=\"java\"><code class=\"language-java\">public String longestPrefixOf(String query) {\n    if (query == null) throw new IllegalArgumentException(\"argument to longestPrefixOf() is null\");\n    int length = longestPrefixOf(root, query, 0, -1);\n    if (length == -1) return null;\n    else return query.substring(0, length);\n}</code></pre>\n\n\n\n<h4 id=\"5-应用\"><a href=\"#5-应用\" class=\"headerlink\" title=\"5.应用\"></a>5.应用</h4><h4 id=\"Leetcode421-Maximum-XOR-of-Two-Numbers-in-an-Array\"><a href=\"#Leetcode421-Maximum-XOR-of-Two-Numbers-in-an-Array\" class=\"headerlink\" title=\"Leetcode421. Maximum XOR of Two Numbers in an Array\"></a><a href=\"https://leetcode-cn.com/problems/maximum-xor-of-two-numbers-in-an-array/\">Leetcode421. Maximum XOR of Two Numbers in an Array</a></h4><p>这道题是典型的字典树的使用的地方。思路十分简单：对于一个无符号整数<code>x</code>来说，与其异或值最大的整数显然是<code>~x</code>；我们贪心地从高位开始，试图取与<code>x</code>的第<code>i</code>位不同的整数，如果这个整数在原数集中，那么它一定是当前已经判断到的位里面最优的一个。字典树为我们很好的实现了判断过程的加速：我们将整数的二进制串存入到字典树中，为了最大化异或值，需要在每一步找到当前比特值的互补比特值：</p>\n<ul>\n<li>如果当前比特值存在互补比特值，访问具有互补比特值的孩子节点，并在异或值最右侧附加一个1。</li>\n<li>如果不存在，直接访问具有当前比特值的孩子节点，并在异或值最右侧附加一个0。</li>\n</ul>\n<p>实现代码如下：</p>\n<pre class=\"line-numbers language-c++\" data-language=\"c++\"><code class=\"language-c++\">#include &lt;bits/stdc++.h&gt;\nusing namespace std;\nclass Trie {\npublic:\n    Trie* next[2];\n    Trie() {\n        memset(next, 0, sizeof(next));\n    }\n};\nclass Solution {\nprivate:\n    Trie* root = new Trie();\npublic:\n    int findMaximumXOR(vector&lt;int&gt;&amp; nums) {\n        //数值存入字典树中\n        for (int num : nums) {\n            Trie* node = root;\n            for (int i = 30; i &gt;= 0; --i) {\n                int bit = num &gt;&gt; i &amp; 1;\n                if (node-&gt;next[bit] == nullptr) {\n                    node-&gt;next[bit] = new Trie();\n                }\n                node = node-&gt;next[bit];\n            }\n        }\n\n        //寻找最大值\n        int res = 0;\n        for (int num : nums) {\n            Trie* node = root;\n            int sum = 0;\n            for (int i = 30; i &gt;= 0; --i) {\n                int bit = num &gt;&gt; i &amp; 1;\n                if (bit == 1) {\n                    sum += node-&gt;next[0] != nullptr ? 1 &lt;&lt; i : 0;\n                    node = node-&gt;next[0] != nullptr ? node-&gt;next[0] : node-&gt;next[1];\n                }\n                else {\n                    sum += node-&gt;next[1] != nullptr ? 1 &lt;&lt; i : 0;\n                    node = node-&gt;next[1] != nullptr ? node-&gt;next[1] : node-&gt;next[0];\n                }\n            }\n            res = max(res, sum);\n        }\n        return res;\n    }\n};</code></pre>\n\n<h4 id=\"212-Word-Search-II\"><a href=\"#212-Word-Search-II\" class=\"headerlink\" title=\"212. Word Search II\"></a><a href=\"https://leetcode-cn.com/problems/word-search-ii/\">212. Word Search II</a></h4><p>为了查找到出现的单词，我们需要进行回溯，而回溯中对于不符合条件的分枝进行快速剪枝的方法就是判断前缀，而这显然需要我们使用字典树这样的数据结构。</p>\n<pre class=\"line-numbers language-java\" data-language=\"java\"><code class=\"language-java\">public List&lt;String&gt; findWords(char[][] board, String[] words) {\n    List&lt;String&gt; res = new ArrayList&lt;&gt;();\n    TrieNode root = buildTrie(words);\n    for (int i = 0; i &lt; board.length; i++) {\n        for (int j = 0; j &lt; board[0].length; j++) {\n            dfs (board, i, j, root, res);\n        }\n    }\n    return res;\n}\n\npublic void dfs(char[][] board, int i, int j, TrieNode p, List&lt;String&gt; res) {\n    char c = board[i][j];\n    if (c == '#' || p.next[c - 'a'] == null) return;\n    p = p.next[c - 'a'];\n    if (p.word != null) {   // found one\n        res.add(p.word);\n        p.word = null;     // de-duplicate\n    }\n\n    board[i][j] = '#';\n    if (i &gt; 0) dfs(board, i - 1, j ,p, res); \n    if (j &gt; 0) dfs(board, i, j - 1, p, res);\n    if (i &lt; board.length - 1) dfs(board, i + 1, j, p, res); \n    if (j &lt; board[0].length - 1) dfs(board, i, j + 1, p, res); \n    board[i][j] = c;\n}\n\npublic TrieNode buildTrie(String[] words) {\n    TrieNode root = new TrieNode();\n    for (String w : words) {\n        TrieNode p = root;\n        for (char c : w.toCharArray()) {\n            int i = c - 'a';\n            if (p.next[i] == null) p.next[i] = new TrieNode();\n            p = p.next[i];\n       }\n       p.word = w;\n    }\n    return root;\n}\n\nclass TrieNode {\n    TrieNode[] next = new TrieNode[26];\n    String word;\n}</code></pre>\n\n","text":"字典树1.简介Trie又称字典树或前缀树，是一种搜索树、一种有序的树状数据结构，用于存储动态集或关联数组，其中键通常是字符串。与二叉搜索树不同的是，树中的任何节点都不存储与该节点相关的整个键，相反，它在树中的位置定义了与之相关的键，即键的值分布在整个结构中。一个节点的所有子代都有...","link":"","photos":[],"count_time":{"symbolsCount":"7.3k","symbolsTime":"7 mins."},"categories":[],"tags":[{"name":"数据结构","slug":"数据结构","count":1,"path":"api/tags/数据结构.json"}],"toc":"<ol class=\"toc\"><li class=\"toc-item toc-level-2\"><a class=\"toc-link\" href=\"#%E5%AD%97%E5%85%B8%E6%A0%91\"><span class=\"toc-text\">字典树</span></a><ol class=\"toc-child\"><li class=\"toc-item toc-level-4\"><a class=\"toc-link\" href=\"#1-%E7%AE%80%E4%BB%8B\"><span class=\"toc-text\">1.简介</span></a></li><li class=\"toc-item toc-level-4\"><a class=\"toc-link\" href=\"#2-%E6%93%8D%E4%BD%9C\"><span class=\"toc-text\">2.操作</span></a><ol class=\"toc-child\"><li class=\"toc-item toc-level-5\"><a class=\"toc-link\" href=\"#%E6%9F%A5%E6%89%BE\"><span class=\"toc-text\">查找</span></a></li><li class=\"toc-item toc-level-5\"><a class=\"toc-link\" href=\"#%E6%8F%92%E5%85%A5\"><span class=\"toc-text\">插入</spa